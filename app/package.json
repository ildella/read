{
  "name": "webapp",
  "version": "4.7.23-0",
  "private": true,
  "type": "module",
  "packageManager": "yarn@4.15.0+sha512.07ec708ac11e2eaa4ea2b04cfbb272812f7e74a753f1595eaef4486c663a98306a30cca3e6fc40f7a0b168dcfb3a2490b6a5e0501e20fb69cc36f563dd161c53",
  "engines": {
    "node": ">=22.7"
  },
  "scripts": {
    "audit": "yarn npm audit --recursive",
    "audit.release": "yarn npm audit --recursive --severity high --exclude ip",
    "build": "yarn build:read",
    "build:chat": "APP=chat vite build",
    "build:chat:watch": "APP=chat vite build --watch",
    "build:read": "APP=read vite build",
    "build:read:watch": "APP=read vite build --watch",
    "check": "svelte-kit sync && svelte-check --tsconfig ./jsconfig.json",
    "check.watch": "svelte-kit sync && svelte-check --tsconfig ./jsconfig.json --watch",
    "clean": "rm -rf node_modules && rm -rf .svelte-kit && echo 'Remember to clean browser storage'",
    "depcheck": "depcheck",
    "dev": "vite dev --host",
    "web": "yarn dev",
    "desktop": "yarn desktop.dev",
    "desktop.dev": "yarn tauri dev",
    "desktop.build": "yarn tauri build -b deb",
    "desktop.build.all": "yarn tauri build",
    "android": "yarn android.dev",
    "android.dev": "yarn tauri android dev",
    "android.build": "yarn tauri android build --apk --split-per-abi",
    "android.build.aarch64": "yarn android.build --target='aarch64'",
    "android.logs": "adb logcat | grep http://tauri.localhost",
    "android.uninstall": "adb uninstall com.multi.app",
    "linux.build": "yarn tauri linux build",
    "lint": "eslint . --cache --max-warnings 80",
    "lint.errors": "yarn lint --quiet",
    "lint.inspect": "npx @eslint/config-inspector",
    "lint.print": "eslint --print-config .eslintrc.cjs > printed-eslint-config.js",
    "preview": "vite preview --host",
    "staging": "yarn build && pm2 reload webapp",
    "test": "yarn vitest",
    "playwright.ci": "CI=true yarn playwright.run --reporter=list",
    "playwright.ci.watch": "CI=true PWTEST_WATCH=1 yarn playwright.run --reporter=list",
    "playwright.record": "npx playwright codegen",
    "playwright.showreport": "playwright show-report",
    "playwright.run": "playwright test",
    "playwright.ui": "yarn playwright.run --ui",
    "playwright.watch": "PWTEST_WATCH=1 && yarn playwright.run",
    "tauri": "tauri",
    "tauri.update": "cd tauri && cargo update",
    "vite": "vite"
  },
  "devDependencies": {
    "@cashu/cashu-ts": "2.6.0",
    "@eslint/compat": "1.3.2",
    "@fontsource/fira-mono": "5.2.6",
    "@fontsource/fira-sans": "5.2.6",
    "@fontsource/inconsolata": "5.2.6",
    "@fontsource/roboto": "5.2.6",
    "@fortawesome/fontawesome-free": "7.0.0",
    "@fortawesome/free-solid-svg-icons": "7.0.0",
    "@getalby/lightning-tools": "5.2.1",
    "@humanspeak/svelte-markdown": "0.8.11",
    "@noble/curves": "1.9.7",
    "@noble/hashes": "1.8.0",
    "@playwright/test": "1.55.0",
    "@stylistic/eslint-plugin-js": "4.4.1",
    "@sveltejs/adapter-static": "3.0.9",
    "@sveltejs/kit": "2.36.2",
    "@sveltejs/vite-plugin-svelte": "6.1.3",
    "@tailwindcss/vite": "4.1.12",
    "@tauri-apps/cli": "2.8.2",
    "@tauri-apps/plugin-os": "2.3.1",
    "axios": "1.11.0",
    "axios-mock-adapter": "2.1.0",
    "bolt11": "1.4.1",
    "date-fns": "4.1.0",
    "date-fns-tz": "3.2.0",
    "debounce": "2.2.0",
    "deepmerge-ts": "7.1.5",
    "dexie": "4.2.0",
    "eslint": "9.34.0",
    "eslint-nostandard": "0.3.6",
    "eslint-plugin-functional": "9.0.2",
    "eslint-plugin-playwright": "2.2.2",
    "eslint-plugin-security": "3.0.1",
    "eslint-plugin-svelte": "3.11.0",
    "eslint-plugin-unicorn": "60.0.0",
    "exstream.js": "0.25.0",
    "globals": "16.3.0",
    "highlight.js": "11.11.1",
    "jsdom": "26.1.0",
    "just-curry-it": "5.3.0",
    "just-debounce-it": "3.2.0",
    "just-is-empty": "3.4.1",
    "just-throttle": "4.2.0",
    "katex": "0.16.22",
    "marked-katex-extension": "5.1.5",
    "minisearch": "7.1.2",
    "nostr-tools": "2.10.4",
    "qrcode": "1.5.4",
    "rss-parser": "3.13.0",
    "svelte": "5.38.3",
    "svelte-check": "4.3.1",
    "svelte-eslint-parser": "1.3.1",
    "svelte-marked": "0.8.0",
    "tailwindcss": "4.1.12",
    "typescript": "5.9.2",
    "uuid": "11.1.0",
    "vite": "7.1.3",
    "vitest": "3.2.4",
    "webln": "0.3.2",
    "workbox-precaching": "7.3.0",
    "ws": "8.18.3",
    "xstream": "11.14.0"
  },
  "dependencies": {
    "@tauri-apps/plugin-opener": "2.5.0",
    "@tauri-apps/plugin-shell": "2.3.0"
  },
  "stableVersion": "4.7.22"
}
